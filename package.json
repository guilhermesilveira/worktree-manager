{
  "name": "worktree-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Multi-repo worktree registry and search helper.",
  "bin": {
    "worktree-manager": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "integration-test": "npm run build && vitest run tests/integration.test.ts"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.7.2",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^4.0.4"
  }
}
